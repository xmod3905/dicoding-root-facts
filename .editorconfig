root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,jsx,ts,tsx,json,yml,yaml,html,css,scss}]
indent_style = space
indent_size = 2

[node_modules/**]
indent_style = ignore
indent_size = ignore

[dist/**]
indent_style = ignore
indent_size = ignore
